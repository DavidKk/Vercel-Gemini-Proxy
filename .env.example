# Gemini Relay — server environment variables
# Copy to `.env` (or set in Vercel Project → Settings → Environment Variables).
# Never commit real secrets.

# --- Proxy mode (optional but recommended for shared deployments) ---
# JSON object of required request headers. All must match (AND).
# Default / example: X-API-KEY. You may add more headers if you want.
# Header names are case-insensitive at runtime (HTTP).
# In .env wrap the JSON in single quotes.
# Server injects GEMINI_API_KEY upstream after auth succeeds.

PROXY_AUTH_HEADERS='{"X-API-KEY":"b4f33b551c4d0156e732ce329b3ae0d4a7c76e90fccd5608"}'

# Google Gemini API key used only in proxy mode (server-side only).
GEMINI_API_KEY=

# --- Passthrough mode (no server env required) ---
# Callers send their own Gemini key via `?key=` or Header `x-goog-api-key`.
# Playground stores the key in browser localStorage and uses passthrough by default.
