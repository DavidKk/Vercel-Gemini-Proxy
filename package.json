{
  "name": "gemini-relay",
  "version": "1.0.0",
  "private": true,
  "description": "Gemini Relay — Gemini API proxy on Vercel with a streaming playground.",
  "scripts": {
    "commit": "git-cz",
    "ci:coverage": "pnpm test",
    "postinstall": "node --experimental-modules ./scripts/postinstall.mjs",
    "preinstall": "node --experimental-modules ./scripts/preinstall.mjs",
    "clear": "rimraf --glob ./libs",
    "format": "prettier --config .prettierrc.js --write \"**/*.{js,jsx,ts,tsx,d.ts,vue,md,json,yml,yaml}\"",
    "lint": "pnpm lint:ts",
    "lint:ts": "eslint -c eslint.config.mjs --fix .",
    "next": "next",
    "build": "next build",
    "dev": "PORT=3000 next dev",
    "test": "jest -c ./jest.config.ts --coverage --reporters=default --reporters=jest-junit",
    "test:watch": "jest --watch",
    "ok": "pnpm format && pnpm lint && pnpm build && pnpm test",
    "test:e2e": "playwright test --reporter=list",
    "dev:e2e": "next dev --hostname 127.0.0.1 --port 3000",
    "prepare": "husky"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "dotenv": "^16.4.5",
    "next": "15.5.9",
    "react": "^19.1.2",
    "react-dom": "^19.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@jest/types": "^29.6.3",
    "@playwright/test": "^1.56.1",
    "@types/chalk": "^2.2.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "autoprefixer": "^10.5.3",
    "chalk": "^5.3.0",
    "commitizen": "^4.2.4",
    "commitlint-plugin-i18n": "^0.0.1-alpha.3",
    "cz-customizable": "^7.2.1",
    "cz-customizable-i18n-config": "^0.0.1-alpha.2",
    "eslint": "^9.7.0",
    "eslint-config-next": "15.5.9",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-runner-tsd": "^6.0.0",
    "json5": "^2.2.3",
    "lint-staged": "^15.2.7",
    "postcss": "^8.5.19",
    "prettier": "^3.3.3",
    "pretty-error": "^4.0.0",
    "rimraf": "^6.0.1",
    "spinnies": "^0.5.1",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.2.1",
    "tsd-lite": "^0.9.0",
    "typescript": "^5.5.3",
    "typescript-transform-paths": "^3.4.7"
  },
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501"
}
