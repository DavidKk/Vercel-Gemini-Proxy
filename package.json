{
  "name": "vercel-gemini-proxy",
  "version": "1.0.0",
  "private": true,
  "description": "Gemini API proxy on Vercel Edge.",
  "scripts": {
    "commit": "git-cz",
    "ci:coverage": "pnpm test",
    "postinstall": "node --experimental-modules ./scripts/postinstall.mjs",
    "preinstall": "node --experimental-modules ./scripts/preinstall.mjs",
    "clear": "rimraf --glob ./libs",
    "format": "prettier --config .prettierrc.js --write \"**/*.{js,jsx,ts,tsx,d.ts,vue,md,json,yml,yaml}\"",
    "lint": "pnpm lint:ts",
    "lint:ts": "eslint -c eslint.config.mjs --fix .",
    "next": "next",
    "build": "next build",
    "dev": "PORT=4000 next dev",
    "test": "jest -c ./jest.config.ts --coverage --reporters=default --reporters=jest-junit",
    "test:watch": "jest --watch",
    "ok": "pnpm format && pnpm lint && pnpm build && pnpm test",
    "test:e2e": "playwright test --reporter=list",
    "dev:e2e": "next dev --hostname 127.0.0.1 --port 3000",
    "prepare": "husky"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "next": "15.5.7",
    "react": "^19.1.2",
    "react-dom": "^19.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@jest/types": "^29.6.3",
    "@playwright/test": "^1.56.1",
    "@types/chalk": "^2.2.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "chalk": "^5.3.0",
    "commitizen": "^4.2.4",
    "commitlint-plugin-i18n": "^0.0.1-alpha.3",
    "cz-customizable": "^7.2.1",
    "cz-customizable-i18n-config": "^0.0.1-alpha.2",
    "eslint": "^9.7.0",
    "eslint-config-next": "15.5.7",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-runner-tsd": "^6.0.0",
    "json5": "^2.2.3",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "pretty-error": "^4.0.0",
    "rimraf": "^6.0.1",
    "spinnies": "^0.5.1",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.2.1",
    "tsd-lite": "^0.9.0",
    "typescript": "^5.5.3",
    "typescript-transform-paths": "^3.4.7"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
